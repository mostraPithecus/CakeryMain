{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "es2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "scripts/**/*",
    "vite.config.ts",
    "astro.config.mjs",
    "src/lib/**/*",
    "src/config/**/*"
  ]
}
